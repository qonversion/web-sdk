{
  "compilerOptions": {
    "declaration": true,
    "module": "commonjs",
    "target": "es2017",
    "strict": true,
    "types": ["node"],
    "skipLibCheck": true,
    "rootDir": "./sdk/src",
    "outDir": "./sdk/build"
  },
  "include": [
    "sdk/src/**/*"
  ],
  "exclude": [
    "sdk/src/__tests__/*",
    "sdk/src/__integrationTests__/*"
  ]
}
